					"numinlets" : 1,
					"numoutlets" : 1,
					"outlettype" : [ "" ],
					"patching_rect" : [ 526.0, 258.0, 21.0, 22.0 ],
					"saved_object_attributes" : 					{
						"parameter_enable" : 0
					}
,
					"text" : "v8",
					"textfile" : 					{
						"text" : "// kickseq.js — bang → list of phase positions for what~\noutlets = 1;\n\nvar maxExtra = 6;      // up to 6 values after the anchor\nvar curveMin = 0.4;    // exponent range (\"degree\" of exp spacing)\nvar curveMax = 4.0;\n\nfunction bang() {\n    var n = 1 + Math.floor(Math.random() * (maxExtra + 1));\n    var curve = curveMin + Math.random() * (curveMax - curveMin);\n    var invert = Math.random() < 0.5;\n    var minGap = 0.1;\n\n    var vals = [0];\n    for (var i = 1; i < n; i++) {\n        var t = i / n;\n        var v = Math.pow(t, curve);\n        if (invert) v = 1 - Math.pow(1 - t, curve);\n\n        // enforce spacing: push forward if too close to previous\n        var prev = vals[vals.length - 1];\n        if (v < prev + minGap) v = prev + minGap;\n\n        // keep clear of the wrap so the last hit isn't < 0.1 from the next anchor\n        if (v > 1 - minGap) break;\n\n        vals.push(v);\n    }\n    outlet(0, vals);\n}\n\n// optional: \"extras 4\" / \"range 0.5 3\" messages\nfunction extras(v) { maxExtra = v; }\nfunction range(lo, hi) { curveMin = lo; curveMax = hi; }",
						"filename" : "none",
						"flags" : 0,
						"embed" : 1,
						"autowatch" : 1
					}

				}

			}
